# ─────────────────────────────────────────────────────────────
# API RAG (assistente jurídico) — usada em app/api/chat/route.js
# ─────────────────────────────────────────────────────────────
# Endpoint da sua API RAG já pronta.
RAG_API_URL=https://sua-api.com/chat
# Token/chave, se a sua API exigir autenticação.
RAG_API_KEY=

# ─────────────────────────────────────────────────────────────
# Text-to-Speech (opcional) — usada em app/api/tts/route.js
# ─────────────────────────────────────────────────────────────
GOOGLE_TTS_API_KEY=
AZURE_TTS_API_KEY=
AZURE_REGION=

# ─────────────────────────────────────────────────────────────
# Bitrix24 CRM — usado em app/api/bitrix/route.js
# ─────────────────────────────────────────────────────────────
# Webhook REST de ENTRADA do seu Bitrix. NUNCA exponha no client.
# Formato: https://SEU.bitrix24.com.br/rest/<user_id>/<token>/
# Se ficar vazio, a rota /api/bitrix opera em MODO MOCK (não chama a rede,
# loga o payload e devolve um dealId simulado) — útil para dev/testes.
BITRIX_WEBHOOK_URL=

# Funil/estágio onde os leads da DAP.IA entram.
# CATEGORY_ID: crm.category.list?entityTypeId=2 (0 = funil padrão)
BITRIX_CATEGORY_ID=0
# STAGE_ID: crm.dealcategory.stage.list?id=<CATEGORY_ID> (ex.: C1:NEW)
BITRIX_STAGE_ID=
# Origem do negócio (SOURCE_ID nativo: WEB, CALL, EMAIL...).
BITRIX_SOURCE_ID=WEB
# Responsável padrão (deixe vazio p/ regra automática do funil).
BITRIX_ASSIGNED_BY_ID=

# Campos customizados (UF_CRM_*) — substitua pelos códigos reais do seu portal.
# Encontre em: CRM > Configurações > Campos personalizados (Negócios),
# ou inspecione crm.deal.fields. Se deixar vazio/placeholder, o campo é ignorado.
BITRIX_UF_WHATSAPP=
BITRIX_UF_TIPO_CASO=
BITRIX_UF_URGENCIA=
BITRIX_UF_ORIGEM_VOZ=
BITRIX_UF_ETAPA=
